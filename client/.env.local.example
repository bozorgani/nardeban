# آدرس بک‌اند (origin) — کد خودش /api و /uploads و /socket.io را اضافه می‌کند،
# پس اینجا فقط دامنه/origin بدون /api بگذارید.
#   ⚠️ اشتباه:  https://yourdomain.com/api   (می‌شود /api/api/... )
#   ✅ درست:    https://yourdomain.com        (nginx مسیرها را به backend می‌فرستد)
# توسعه:        http://localhost:4000
# پروداکشن با nginx روی همان دامنه:  https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# آدرس سایت برای sitemap و metadata (دامنهٔ عمومی فرانت)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
