# پورتی که Render به آن گوش می‌دهد (Render خودش این را تنظیم می‌کند)
PORT=4000

# اتصال MongoDB Atlas — در پروداکشن کلید خودتان را بگذارید
# نمونه رایگان: https://www.mongodb.com/atlas/database
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nardeban

# کلید امضای JWT (یک رشته‌ی تصادفی طولانی)
JWT_SECRET=change-me-to-a-long-random-string

# دامنه‌ی فرانت (Vercel) — برای CORS
# بعد از deploy فرانت، دامنه‌ی واقعی را بگذارید: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# آدرس سایت برای sitemap
SITE_URL=http://localhost:3000

# محیط اجرا — در پروداکشن حتماً production باشد (کد OTP فقط در توسعه در پاسخ برمی‌گردد)
NODE_ENV=development

# سرویس پیامک کد تایید (SEC-01)
#   kavenegar → ارسال واقعی با کاوه‌نگار
#   console   → فقط چاپ در کنسول (پیش‌فرض توسعه)
#   none      → غیرفعال (پیش‌فرض پروداکشن اگر تنظیم نشود؛ درخواست OTP خطا می‌دهد)
SMS_PROVIDER=console
# برای ارسال واقعی با کاوه‌نگار:
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=verify

# Web Push (نوتیفیکیشن چت) — برای پروداکشن: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
