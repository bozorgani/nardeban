# پورتی که بک‌اند به آن گوش می‌دهد
PORT=4000

# اتصال MongoDB Atlas — در پروداکشن کلید خودتان را بگذارید
# می‌توانید MongoDB را با Docker اجرا کنید (به docker-compose.yml نگاه کنید) یا Atlas
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/nardeban

# کلید امضای JWT — الزامی در پروداکشن، حداقل ۳۲ کاراکتر و غیرپیش‌فرض (SEC-02)
# تولید کلید امن:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# اگر در پروداکشن تنظیم نشود یا ضعیف باشد، سرور هنگام بوت متوقف می‌شود.
JWT_SECRET=change-me-to-a-long-random-string

# دامنهٔ فرانت برای CORS (SEC-06)
# در پروداکشن «الزامی» و باید دقیقاً origin واقعی باشد (با https و بدون اسلش پایانی).
# چون احراز هویت با کوکی است (credentials)، فقط همین origin(ها) مجاز خواهند بود؛
# localhost/IP خصوصی در پروداکشن مجاز نیست. چندتایی با کاما: https://a.com,https://b.com
# مثال پروداکشن: CLIENT_ORIGIN=https://nardeban.example.com
CLIENT_ORIGIN=http://localhost:3000

# آدرس سایت برای sitemap
SITE_URL=http://localhost:3000

# تنظیمات کوکی توکن (مهم برای کارکرد لاگین)
#   COOKIE_SECURE:  true فقط روی HTTPS. اگر هنوز SSL نداری و سایت روی http است،
#     این را false بگذار وگرنه مرورگر کوکی را ذخیره نمی‌کند و «لطفا وارد شوید» می‌گیری.
#   COOKIE_SAMESITE: lax (پیش‌فرض، وقتی فرانت و API هم‌دامنه‌اند پشت nginx).
#     اگر فرانت و API روی دامنهٔ متفاوت‌اند → none (که خودکار secure را true می‌کند، نیازمند HTTPS).
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# مسیر ذخیرهٔ آپلودها (اختیاری) — پیش‌فرض: <server>/uploads یعنی /app/uploads در Docker
# در Docker این مسیر روی والیوم پایدار uploads_data نگاشت می‌شود (OPS-04).
# UPLOAD_DIR=/app/uploads

# محیط اجرا — در پروداکشن حتماً production باشد (کد OTP فقط در توسعه در پاسخ برمی‌گردد)
NODE_ENV=development

# سرویس پیامک کد تایید (SEC-01)
#   smsir     → ارسال واقعی با sms.ir (پیشنهادی برای تولید)
#   kavenegar → ارسال واقعی با کاوه‌نگار
#   console   → فقط چاپ در کنسول (پیش‌فرض توسعه)
#   none      → غیرفعال (پیش‌فرض پروداکشن اگر تنظیم نشود؛ درخواست OTP خطا می‌دهد)
# چاپ کد OTP در لاگ سرور برای دیباگ (فقط موقت؛ در پروداکشن خاموش بماند)
LOG_OTP=false

SMS_PROVIDER=smsir

# --- sms.ir (Verify Send) ---
# توکن را از پنل sms.ir بگیرید و فقط در server/.env واقعی بگذارید (هرگز اینجا commit نکنید)
SMSIR_API_KEY=
SMSIR_TEMPLATE_ID=
SMSIR_PARAM_NAME=CODE

# --- کاوه‌نگار (اختیاری) ---
KAVENEGAR_API_KEY=
KAVENEGAR_TEMPLATE=verify

# Web Push (نوتیفیکیشن چت) — SEC-03
# کلیدها فقط از همین‌جا خوانده می‌شوند (هیچ کلیدی در سورس هاردکد نیست).
# اگر خالی بمانند، Web Push بی‌صدا غیرفعال می‌شود (بدون کرش).
# ساخت کلید:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
