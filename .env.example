# ============================================================================
# متغیرهای docker-compose (این فایل را به .env کپی کنید: cp .env.example .env)
# docker compose به‌صورت خودکار فایل .env کنار compose را برای interpolation می‌خواند.
# ============================================================================

# --- MongoDB (احراز هویت داخلی) ---
MONGO_USER=nardeban
# ⚠️ یک رمز قوی بگذارید (در پروداکشن الزامی):
MONGO_PASS=change-me-strong-mongo-password

# --- آدرس‌های عمومی فرانت (در زمان build داخل باندل bake می‌شوند) ---
# ⚠️ فقط origin بدهید، بدون /api — کد خودش /api و /uploads و /socket.io را اضافه می‌کند.
#   ✅ درست:  NEXT_PUBLIC_API_URL=https://nardeban.example.com   (یا http://194.5.192.245)
#   ❌ غلط:   NEXT_PUBLIC_API_URL=/api  یا  .../api   →  باعث /api/api/... می‌شود
# با nginx جلوی پروژه، همه‌چیز از طریق همان دامنه می‌رود و کاربر backend را مستقیم نمی‌بیند.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- پورت‌هایی که فقط روی لوکال‌هاست سرور bind می‌شوند (nginx جلوی آن‌ها می‌نشیند) ---
BACKEND_PORT=4000
FRONTEND_PORT=3000
